# ╔══════════════════════════════════════════════════════════════╗
# ║         ليكير — Lecker Candy Store — Environment Setup       ║
# ╚══════════════════════════════════════════════════════════════╝
#
# 1. انسخ هذا الملف: cp .env.example .env
# 2. عبّئ القيم أدناه
# 3. شغّل: pnpm install && pnpm setup && pnpm dev

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔴 مطلوب (REQUIRED)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# PostgreSQL connection string
# خيارات مجانية:
#   - Neon:    https://neon.tech          (ابحث عن "Connection string")
#   - Supabase: https://supabase.com      (Settings → Database → Connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔴 مطلوب في الإنتاج / اختياري في التطوير
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# مفتاح الجلسة — أي نص عشوائي طويل (مثلاً: openssl rand -hex 32)
# في التطوير يمكن تركه، في الإنتاج مطلوب
SESSION_SECRET=replace-with-random-secret-min-32-chars

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🟡 اختياري — SMS عبر Twilio
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# بدون Twilio: رمز OTP يظهر في الـ console log فقط
# للإنتاج الحقيقي: أنشئ حساباً على https://www.twilio.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# رقم هاتف الأدمن (صاحب المتجر) لاستقبال إشعارات SMS بالطلبات الجديدة
# مثال: +972501234567
ADMIN_PHONE_NUMBER=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚙️  إعدادات المنافذ (اختياري — قيم افتراضية)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PORT=3001       # Backend API port (default: 3001)
# API_PORT=3001   # Frontend proxy target (default: 3001)
