# =============================================
# Lecker - متجر الحلويات — Environment Variables
# =============================================
# انسخ هذا الملف وسمّه .env وعبّئ القيم

# ─── قاعدة البيانات (PostgreSQL) ──────────────
# خيار 1: استخدم Neon (مجاني): https://neon.tech
# خيار 2: استخدم Supabase (مجاني): https://supabase.com
# خيار 3: ثبّت PostgreSQL محلياً
DATABASE_URL=postgresql://user:password@localhost:5432/lecker

# ─── الجلسات ──────────────────────────────────
# أي نص عشوائي طويل (مهم في الإنتاج)
SESSION_SECRET=change-this-to-a-random-secret-in-production

# ─── Twilio (للـ SMS) ─────────────────────────
# أنشئ حساباً على: https://www.twilio.com
# يمكن تركها فارغة إذا لا تريد SMS (الموقع سيشتغل بدونها)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# رقم الأدمن الذي يستقبل إشعارات SMS بالطلبات الجديدة
ADMIN_PHONE_NUMBER=

# ─── المنافذ (اختياري — لها قيم افتراضية) ───────
# PORT=3001        # الـ backend (افتراضي: 3001)
# API_PORT=3001    # منفذ الـ API للـ frontend proxy (افتراضي: 3001)
